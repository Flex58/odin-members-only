<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Document</title>
</head>
<body>
		<% if (currentUser) {%>
		<div>
			<h1>Welcome Back 
				<% if (currentUser.admin) {  %> 
					Admin
				<% } else if (currentUser.member) { %> 
				  Member 
				<% } %>
				<%= currentUser.first_name %> </h1>
			<a href="/account/member"><button>Become a Member</button></a>
			<a href="/account/sign-out"><button>Log Out</button></a>
		</div>
		<form action="/messages/post" method="post">
			<%- include('partials/errors.ejs') %>
			<div>
				<label for="title">Title</label>
				<input type="text" name="title" id="title" 
							 value="<%= locals.title || ''%>">
			</div>
			<div>
				<label for="content">Message</label>
				<textarea name="content" id="content" rows="5" cols="30"
				><%= locals.content || '' %></textarea>
			</div>
			<button>Post Message</button>
		</form>
	  <!-- Create New Message -->	
		<% } else {%>
			<a href="/account/sign-in"><Button>Log-in</Button></a>
			<a href="/account/sign-up"><Button>Sign-up</Button></a>
		<!--  -->
		<% } %>

		<%- include('partials/messages.ejs') %>
</body>
</html>
